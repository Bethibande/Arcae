<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1769103270386-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="RepositoryBackend_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769103270386-2"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="Repository_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769103270386-3"
               author="bethibande">
        <createTable tableName="Repository">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_repository"/>
            </column>
            <column name="name"
                    type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="type"
                    type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="settings"
                    type="jsonb"/>
            <column name="backend_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769103270386-4"
               author="bethibande">
        <createTable tableName="RepositoryBackend">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_repositorybackend"/>
            </column>
            <column name="name"
                    type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type"
                    type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="settings"
                    type="jsonb"/>
        </createTable>
    </changeSet>
    <changeSet id="1769103270386-5"
               author="bethibande">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_repository_name"
                             tableName="Repository"/>
    </changeSet>
    <changeSet id="1769103270386-6"
               author="bethibande">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_repositorybackend_name"
                             tableName="RepositoryBackend"/>
    </changeSet>
    <changeSet id="1769103270386-7"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="backend_id"
                                 baseTableName="Repository"
                                 constraintName="FK_REPOSITORY_ON_BACKEND"
                                 referencedColumnNames="id"
                                 referencedTableName="RepositoryBackend"/>
    </changeSet>

    <changeSet id="1769158198470-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="ArtifactVersion_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769158198470-2"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="Artifact_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769158198470-3"
               author="bethibande">
        <createTable tableName="Artifact">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_artifact"/>
            </column>
            <column name="repository_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="groupId"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="artifactId"
                    type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769158198470-4"
               author="bethibande">
        <createTable tableName="ArtifactVersion">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_artifactversion"/>
            </column>
            <column name="artifact_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="version"
                    type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769158198470-5"
               author="bethibande">
        <addUniqueConstraint columnNames="artifactId"
                             constraintName="uc_artifact_artifactid"
                             tableName="Artifact"/>
    </changeSet>
    <changeSet id="1769158198470-6"
               author="bethibande">
        <addUniqueConstraint columnNames="groupId"
                             constraintName="uc_artifact_groupid"
                             tableName="Artifact"/>
    </changeSet>
    <changeSet id="1769158198470-7"
               author="bethibande">
        <addUniqueConstraint columnNames="version"
                             constraintName="uc_artifactversion_version"
                             tableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1769158198470-8"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="artifact_id"
                                 baseTableName="ArtifactVersion"
                                 constraintName="FK_ARTIFACTVERSION_ON_ARTIFACT"
                                 referencedColumnNames="id"
                                 referencedTableName="Artifact"/>
    </changeSet>
    <changeSet id="1769158198470-9"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="repository_id"
                                 baseTableName="Artifact"
                                 constraintName="FK_ARTIFACT_ON_REPOSITORY"
                                 referencedColumnNames="id"
                                 referencedTableName="Repository"/>
    </changeSet>

    <changeSet id="1769159501511-1"
               author="bethibande">
        <addColumn tableName="ArtifactVersion">
            <column name="created"
                    type="DATETIME"/>
            <column name="updated"
                    type="DATETIME"/>
        </addColumn>
    </changeSet>
    <changeSet id="1769159501511-2"
               author="bethibande">
        <addNotNullConstraint columnName="created"
                              tableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1769159501511-4"
               author="bethibande">
        <addNotNullConstraint columnName="updated"
                              tableName="ArtifactVersion"/>
    </changeSet>

    <changeSet id="1769180285832-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="Users_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769245544460-2"
               author="maxbb">
        <createTable tableName="User_roles">
            <column name="User_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="roles"
                    type="varchar(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1769245544460-3"
               author="maxbb">
        <createTable tableName="Users">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_users"/>
            </column>
            <column name="name"
                    type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="email"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="password"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769245544460-6"
               author="maxbb">
        <addForeignKeyConstraint baseColumnNames="User_id"
                                 baseTableName="User_roles"
                                 constraintName="fk_user_roles_on_user"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>
    <changeSet id="1769180285832-3"
               author="bethibande">
        <addUniqueConstraint columnNames="email"
                             constraintName="uc_users_email"
                             tableName="Users"/>
    </changeSet>
    <changeSet id="1769180285832-4"
               author="bethibande">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_users_name"
                             tableName="Users"/>
    </changeSet>
</databaseChangeLog>