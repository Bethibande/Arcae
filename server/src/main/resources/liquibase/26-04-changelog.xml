            <column name="authorizationEndpoint"
                    type="varchar(512)"/>
            <column name="tokenEndpoint"
                    type="varchar(512)"/>
            <column name="userInfoEndpoint"
                    type="varchar(512)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775028501244-3"
               author="bethibande">
        <addNotNullConstraint columnName="authorizationEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-5"
               author="bethibande">
        <addNotNullConstraint columnName="tokenEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-7"
               author="bethibande">
        <addNotNullConstraint columnName="userInfoEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-1"
               author="bethibande">
        <dropNotNullConstraint columnDataType="varchar(512)"
