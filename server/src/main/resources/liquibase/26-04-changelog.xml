    <changeSet id="1775289642505-1"
               author="bethibande">
        <addColumn tableName="UserSession">
            <column name="address"
                    type="varchar(512)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775290794930-1" author="bethibande">
        <sql>
            UPDATE usersession SET address = ''
        </sql>
    </changeSet>
    <changeSet id="1775289642505-2"
               author="bethibande">
        <addNotNullConstraint columnName="address"
                              tableName="UserSession"/>
    </changeSet>

    <changeSet id="1775291640786-1"
               author="bethibande">
        <addColumn tableName="UserSession">
            <column name="refreshToken_id"
                    type="BIGINT"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775291669515-1" author="bethibande">
        <!-- Invalidate all active sessions due to database validation constraints, the frontend will automatically renew them anyway -->
        <sql>
            DELETE FROM usersession
        </sql>
    </changeSet>
    <changeSet id="1775291640786-2"
               author="bethibande">
        <addNotNullConstraint columnName="refreshToken_id"
                              tableName="UserSession"/>
    </changeSet>
    <changeSet id="1775291640786-3"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="refreshToken_id"
                                 baseTableName="UserSession"
                                 constraintName="FK_USERSESSION_ON_REFRESHTOKEN"
                                 referencedColumnNames="id"
                                 referencedTableName="RefreshToken"/>
    </changeSet>

    <changeSet id="1775468556938-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="HelmMetadata_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1775468556938-2"
               author="bethibande">
        <createTable tableName="HelmMetadata">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_helmmetadata"/>
            </column>
            <column name="version_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="data"
                    type="jsonb">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1775468556938-3"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="version_id"
                                 baseTableName="HelmMetadata"
                                 constraintName="FK_HELMMETADATA_ON_VERSION"
                                 referencedColumnNames="id"
                                 referencedTableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1775469046095-1" author="bethibande">
        <createIndex tableName="HelmMetadata" indexName="idx_HelmMetadata_ArtifactVersion">
            <column name="version_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="1776516577230-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="OpenIDConnectLogo_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1776516577230-2"
               author="bethibande">
        <createTable tableName="OpenIDConnectLogo">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_openidconnectlogo"/>
            </column>
            <column name="provider_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="createdAt"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="data"
                    type="bytea">
                <constraints nullable="false"/>
            </column>
            <column name="contentType"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1776516577230-3"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="provider_id"
                                 baseTableName="OpenIDConnectLogo"
                                 constraintName="FK_OPENIDCONNECTLOGO_ON_PROVIDER"
                                 referencedColumnNames="id"
                                 referencedTableName="OpenIDConnectProvider"/>
    </changeSet>

    <changeSet id="1776519857233-1" author="bethibande">
        <insert tableName="scheduledjob">
            <column name="id" valueComputed="nextval('ScheduledJob_seq')"/>
            <column name="type">CLEAN_UP_DATABASE</column>
            <column name="cronSchedule">0 1 * * *</column> <!-- Every day at 01:00 UTC -->
            <column name="nextRunAt">now()</column>
            <column name="deleteAfterRun">false</column>
        </insert>
    </changeSet>

    <changeSet id="1777046570491-1" author="bethibande">
        <sql>
            DELETE FROM helmmetadata hm USING (
                SELECT version_id, MAX(id) AS keep_id
                FROM helmmetadata
                GROUP BY version_id
            ) KEEP
            WHERE hm.version_id = keep.version_id
              AND hm.id &lt;&gt; keep.keep_id;
        </sql>
    </changeSet>
    <changeSet id="1777046542794-1" author="bethibande">
        <addUniqueConstraint tableName="HelmMetadata" columnNames="version_id"/>
    </changeSet>

    <changeSet id="1777105695630-1"
               author="bethibande">
