<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1773481713099-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="SystemProperty_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1773481713099-2"
               author="bethibande">
        <createTable tableName="SystemProperty">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_systemproperty"/>
            </column>
            <column name="key"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="value"
                    type="jsonb">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1773481713099-3"
               author="bethibande">
        <addUniqueConstraint columnNames="key"
                             constraintName="uc_systemproperty_key"
                             tableName="SystemProperty"/>
    </changeSet>

    <changeSet id="1773482613718-1" author="bethibande">
        <createIndex tableName="systemproperty" indexName="idx_SystemProperty_key">
            <column name="key"/>
        </createIndex>
    </changeSet>

    <changeSet id="1773502055883-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="PasswordResetToken_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1773502055883-2"
               author="bethibande">
        <createTable tableName="PasswordResetToken">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_passwordresettoken"/>
            </column>
            <column name="user_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="token"
                    type="varchar(9)">
                <constraints nullable="false"/>
            </column>
            <column name="expiration"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1773502055883-3"
               author="bethibande">
        <addUniqueConstraint columnNames="token"
                             constraintName="uc_passwordresettoken_token"
                             tableName="PasswordResetToken"/>
    </changeSet>
    <changeSet id="1773502055883-4"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="PasswordResetToken"
                                 constraintName="FK_PASSWORDRESETTOKEN_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>

    <changeSet id="1773505919502-1" author="bethibande">
        <createIndex tableName="passwordresettoken" indexName="idx_PasswordResetToken_token">
            <column name="token"/>
        </createIndex>
        <createIndex tableName="PasswordResetToken" indexName="idx_PasswordResetToken_expiration">
            <column name="expiration"/>
        </createIndex>
    </changeSet>

    <changeSet id="1774108872407-1"
               author="bethibande">
        <addColumn tableName="ScheduledJob">
            <column name="assignedAt"
                    type="timestamptz"/>
        </addColumn>
    </changeSet>

    <changeSet id="1774798309683-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="OpenIDConnectProvider_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1774798309683-2"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="OpenIDConnection_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1774798309683-3"
               author="bethibande">
        <createTable tableName="OpenIDConnectProvider">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_openidconnectprovider"/>
            </column>
            <column name="name"
                    type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="clientId"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="clientSecret"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="discoveryUrl"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1774798309683-4"
               author="bethibande">
        <createTable tableName="OpenIDConnection">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_openidconnection"/>
            </column>
            <column name="user_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="provider_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="subject"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1774798309683-5"
               author="bethibande">
        <addUniqueConstraint columnNames="provider_id, subject"
                             constraintName="uc_751dca966ff9f22fabfddd066"
                             tableName="OpenIDConnection"/>
    </changeSet>
    <changeSet id="1774798309683-6"
               author="bethibande">
        <addUniqueConstraint columnNames="user_id, provider_id"
                             constraintName="uc_9c961502b92de6f420230e9a0"
                             tableName="OpenIDConnection"/>
    </changeSet>
    <changeSet id="1774798309683-7"
               author="bethibande">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_openidconnectprovider_name"
                             tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1774798309683-8"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="provider_id"
                                 baseTableName="OpenIDConnection"
                                 constraintName="FK_OPENIDCONNECTION_ON_PROVIDER"
                                 referencedColumnNames="id"
                                 referencedTableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1774798309683-9"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="OpenIDConnection"
                                 constraintName="FK_OPENIDCONNECTION_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>

</databaseChangeLog>