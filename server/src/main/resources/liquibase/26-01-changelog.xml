<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1769519227119-1"
               author="maxbb">
        <createSequence incrementBy="50"
                        sequenceName="ArtifactVersion_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769519227119-2"
               author="maxbb">
        <createSequence incrementBy="50"
                        sequenceName="Artifact_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769519227119-3"
               author="maxbb">
        <createSequence incrementBy="50"
                        sequenceName="Repository_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769519227119-4"
               author="maxbb">
        <createSequence incrementBy="50"
                        sequenceName="Users_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769519227119-5"
               author="maxbb">
        <createTable tableName="Artifact">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_artifact"/>
            </column>
            <column name="repository_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="groupId"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="artifactId"
                    type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769519227119-6"
               author="maxbb">
        <createTable tableName="ArtifactVersion">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_artifactversion"/>
            </column>
            <column name="artifact_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="version"
                    type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="created"
                    type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated"
                    type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769519227119-7"
               author="maxbb">
        <createTable tableName="Repository">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_repository"/>
            </column>
            <column name="name"
                    type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="packageManager"
                    type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="settings"
                    type="jsonb"/>
        </createTable>
    </changeSet>
    <changeSet id="1769519227119-8"
               author="maxbb">
        <createTable tableName="User_roles">
            <column name="User_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="roles"
                    type="varchar(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1769519227119-9"
               author="maxbb">
        <createTable tableName="Users">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_users"/>
            </column>
            <column name="name"
                    type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="email"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="password"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769519227119-10"
               author="maxbb">
        <addUniqueConstraint columnNames="artifactId"
                             constraintName="uc_artifact_artifactid"
                             tableName="Artifact"/>
    </changeSet>
    <changeSet id="1769519227119-11"
               author="maxbb">
        <addUniqueConstraint columnNames="groupId"
                             constraintName="uc_artifact_groupid"
                             tableName="Artifact"/>
    </changeSet>
    <changeSet id="1769519227119-12"
               author="maxbb">
        <addUniqueConstraint columnNames="version"
                             constraintName="uc_artifactversion_version"
                             tableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1769519227119-13"
               author="maxbb">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_repository_name"
                             tableName="Repository"/>
    </changeSet>
    <changeSet id="1769519227119-14"
               author="maxbb">
        <addUniqueConstraint columnNames="email"
                             constraintName="uc_users_email"
                             tableName="Users"/>
    </changeSet>
    <changeSet id="1769519227119-15"
               author="maxbb">
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_users_name"
                             tableName="Users"/>
    </changeSet>
    <changeSet id="1769519227119-16"
               author="maxbb">
        <addForeignKeyConstraint baseColumnNames="artifact_id"
                                 baseTableName="ArtifactVersion"
                                 constraintName="FK_ARTIFACTVERSION_ON_ARTIFACT"
                                 referencedColumnNames="id"
                                 referencedTableName="Artifact"/>
    </changeSet>
    <changeSet id="1769519227119-17"
               author="maxbb">
        <addForeignKeyConstraint baseColumnNames="repository_id"
                                 baseTableName="Artifact"
                                 constraintName="FK_ARTIFACT_ON_REPOSITORY"
                                 referencedColumnNames="id"
                                 referencedTableName="Repository"/>
    </changeSet>
    <changeSet id="1769519227119-18"
               author="maxbb">
        <addForeignKeyConstraint baseColumnNames="User_id"
                                 baseTableName="User_roles"
                                 constraintName="fk_user_roles_on_user"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>
</databaseChangeLog>