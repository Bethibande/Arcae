<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1769943556375-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="StoredFile_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769943556375-2"
               author="bethibande">
        <createTable tableName="ArtifactVersion_files">
            <column name="ArtifactVersion_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="files_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769943556375-3"
               author="bethibande">
        <createTable tableName="StoredFile">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_storedfile"/>
            </column>
            <column name="repository_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="key"
                    type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769943556375-4"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="repository_id"
                                 baseTableName="StoredFile"
                                 constraintName="FK_STOREDFILE_ON_REPOSITORY"
                                 referencedColumnNames="id"
                                 referencedTableName="Repository"/>
    </changeSet>
    <changeSet id="1769943556375-5"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="ArtifactVersion_id"
                                 baseTableName="ArtifactVersion_files"
                                 constraintName="fk_artfil_on_artifact_version"
                                 referencedColumnNames="id"
                                 referencedTableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1769943556375-6"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="files_id"
                                 baseTableName="ArtifactVersion_files"
                                 constraintName="fk_artfil_on_stored_file"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>

    <changeSet id="1769950427746-1"
               author="bethibande">
        <createTable tableName="Artifact_files">
            <column name="Artifact_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="files_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769950427746-2"
               author="bethibande">
        <addColumn tableName="StoredFile">
            <column name="created"
                    type="timestamptz"/>
            <column name="hashes"
                    type="jsonb"/>
            <column name="updated"
                    type="timestamptz"/>
        </addColumn>
    </changeSet>
    <changeSet id="1769950427746-3"
               author="bethibande">
        <addNotNullConstraint columnName="created"
                              tableName="StoredFile"/>
    </changeSet>
    <changeSet id="1769950427746-6"
               author="bethibande">
        <addNotNullConstraint columnName="updated"
                              tableName="StoredFile"/>
    </changeSet>
    <changeSet id="1769950427746-7"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="Artifact_id"
                                 baseTableName="Artifact_files"
                                 constraintName="fk_artfil_on_artifact"
                                 referencedColumnNames="id"
                                 referencedTableName="Artifact"/>
    </changeSet>
    <changeSet id="1769950427746-8"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="files_id"
                                 baseTableName="Artifact_files"
                                 constraintName="fk_artfil_on_stored_file"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>

    <changeSet id="1769969568855-1" author="bethibande">
        <sql>
            UPDATE repository
            SET packagemanager = 'MAVEN'
            WHERE packagemanager = 'MAVEN_3';
        </sql>
    </changeSet>

    <changeSet id="1770035947861-1"
               author="bethibande">
        <addColumn tableName="Repository">
            <column name="cleanupPolicies"
                    type="jsonb"/>
        </addColumn>
    </changeSet>

    <changeSet id="1770114595082-1"
               author="behtibande">
        <createSequence incrementBy="50"
                        sequenceName="TaskLock_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1770114595082-2"
               author="behtibande">
        <createTable tableName="TaskLock">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_tasklock"/>
            </column>
            <column name="taskId"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="doNotExecuteBefore"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="lock"
                    type="varchar(255)"/>
            <column name="lockEnd"
                    type="timestamptz"/>
            <column name="lastSuccess"
                    type="timestamptz"/>
        </createTable>
    </changeSet>
    <changeSet id="1770114595082-3"
               author="behtibande">
        <addUniqueConstraint columnNames="taskId"
                             constraintName="uc_tasklock_taskid"
                             tableName="TaskLock"/>
    </changeSet>

    <changeSet id="1770133651187-1"
               author="behtibande">
        <createSequence incrementBy="50"
                        sequenceName="UserSession_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1770133651187-2"
               author="behtibande">
        <createTable tableName="UserSession">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_usersession"/>
            </column>
            <column name="token"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="device"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1770133651187-3"
               author="behtibande">
        <addUniqueConstraint columnNames="token"
                             constraintName="uc_usersession_token"
                             tableName="UserSession"/>
    </changeSet>
    <changeSet id="1770133651187-4"
               author="behtibande">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="UserSession"
                                 constraintName="FK_USERSESSION_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>
    <changeSet id="1770134319183-1" author="bethibande">
        <createIndex tableName="UserSession" indexName="idx_usersession_token">
            <column name="token"/>
        </createIndex>
    </changeSet>
    <changeSet id="1770136876985-1" author="bethibande">
        <dropColumn tableName="UserSession">
            <column name="device"/>
        </dropColumn>
    </changeSet>

    <changeSet id="1770477917659-1"
               author="bethibande">
        <addColumn tableName="ArtifactVersion">
            <column name="manifest_id"
                    type="BIGINT"/>
        </addColumn>
    </changeSet>
    <changeSet id="1770477917659-2"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="manifest_id"
                                 baseTableName="ArtifactVersion"
                                 constraintName="FK_ARTIFACTVERSION_ON_MANIFEST"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>
    <changeSet id="1770544181642-1" author="bethibande">
        <addUniqueConstraint tableName="Artifact" columnNames="repository_id,artifactId,groupId"/>
    </changeSet>
    <changeSet id="1770548189574-1" author="bethibande">
        <addUniqueConstraint tableName="ArtifactVersion" columnNames="artifact_id,version"/>
    </changeSet>

    <changeSet id="1770553614979-1"
               author="bethibande">
        <addColumn tableName="Repository">
            <column name="metadata"
                    type="jsonb"/>
        </addColumn>
    </changeSet>
    <changeSet id="1770558297378-1"
               author="bethibande">
        <addColumn tableName="StoredFile">
            <column name="contentLength"
                    type="BIGINT"/>
            <column name="contentType"
                    type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="1770559887302-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="OCISubject_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1770559887302-2"
               author="bethibande">
        <createTable tableName="OCISubject">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_ocisubject"/>
            </column>
            <column name="source_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="subject_id"
                    type="BIGINT"/>
            <column name="subjectDigest"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="artifactType"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1770559887302-3"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="source_id"
                                 baseTableName="OCISubject"
                                 constraintName="FK_OCISUBJECT_ON_SOURCE"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>
    <changeSet id="1770559887302-4"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="subject_id"
                                 baseTableName="OCISubject"
                                 constraintName="FK_OCISUBJECT_ON_SUBJECT"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>
    <changeSet id="1770564855803-1"
               author="bethibande">
        <createTable tableName="OCISubject_annotations">
            <column name="OCISubject_id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_ocisubject_annotations"/>
            </column>
            <column name="annotations"
                    type="VARCHAR(255)"/>
            <column name="annotations_key"
                    type="VARCHAR(255)">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_ocisubject_annotations"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1770564855803-2"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="OCISubject_id"
                                 baseTableName="OCISubject_annotations"
                                 constraintName="fk_ocisubject_annotations_on_o_c_i_subject"
                                 referencedColumnNames="id"
                                 referencedTableName="OCISubject"/>
    </changeSet>
    <changeSet id="1770565242970-2"
               author="bethibande">
        <addColumn tableName="OCISubject">
            <column name="namespace"
                    type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="1770569959963-2"
               author="bethibande">
        <addColumn tableName="OCISubject">
            <column name="sourceDigest"
                    type="varchar(255)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1770569959963-3"
               author="bethibande">
        <addNotNullConstraint columnName="sourceDigest"
                              tableName="OCISubject"/>
    </changeSet>
    <changeSet id="1770569959963-1"
               author="bethibande">
        <addNotNullConstraint columnDataType="varchar(255)"
                              columnName="namespace"
                              tableName="OCISubject"
                              validate="true"/>
    </changeSet>

    <changeSet id="1771698048998-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="ScheduledJob_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1771698048998-2"
               author="bethibande">
        <createTable tableName="ScheduledJob">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_scheduledjob"/>
            </column>
            <column name="type"
                    type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="settings"
                    type="jsonb"/>
            <column name="cronSchedule"
                    type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="nextRunAt"
                    type="timestamptz"/>
            <column name="deleteAfterRun"
                    type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="runner"
                    type="varchar(256)"/>
            <column name="lastSuccessfulRun"
                    type="timestamptz"/>
        </createTable>
    </changeSet>

    <changeSet id="1771698435326-1" author="bethibande">
        <insert tableName="scheduledjob">
            <column name="id" valueComputed="nextval('ScheduledJob_seq')"/>
            <column name="type">DELETE_OLD_VERSIONS</column>
            <column name="cronSchedule">* * * * *</column> <!-- Once per minute -->
            <column name="nextRunAt">now()</column>
            <column name="deleteAfterRun">false</column>
        </insert>
    </changeSet>

    <changeSet id="1771698905127-1" author="bethibande">
        <dropTable tableName="tasklock"/>
    </changeSet>
    <changeSet id="1771698923187-1" author="bethibande">
        <dropSequence sequenceName="tasklock_seq"/>
    </changeSet>

    <changeSet id="1771766688502-1" author="bethibande">
        <insert tableName="scheduledjob">
            <column name="id" valueComputed="nextval('ScheduledJob_seq')"/>
            <column name="type">DELETE_EXPIRED_SESSIONS</column>
            <column name="cronSchedule">0 1 * * *</column> <!-- Every day at 01:00 UTC -->
            <column name="nextRunAt">now()</column>
            <column name="deleteAfterRun">false</column>
        </insert>
    </changeSet>

    <changeSet id="1771769145204-1" author="bethibande">
        <insert tableName="scheduledjob">
            <column name="id" valueComputed="nextval('ScheduledJob_seq')"/>
            <column name="type">CLEAN_UP_ORPHANED_FILES</column>
            <column name="cronSchedule">0 1 * * *</column> <!-- Every day at 01:00 UTC -->
            <column name="nextRunAt">now()</column>
            <column name="deleteAfterRun">false</column>
        </insert>
    </changeSet>

    <changeSet id="1771774655044-1"
               author="bethibande">
        <!-- Messed up the author, so we need this to prevent re-runs on existing deployments -->
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="ScheduledJob" columnName="executionStartedAt"/>
            </not>
        </preConditions>

        <addColumn tableName="ScheduledJob">
            <column name="executionStartedAt"
                    type="timestamptz"/>
        </addColumn>
    </changeSet>
    <changeSet id="1771841226713-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="RefreshToken_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1771841226713-2"
               author="bethibande">
        <createTable tableName="RefreshToken">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_refreshtoken"/>
            </column>
            <column name="user_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="token"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="created"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1771841226713-3"
               author="bethibande">
        <addUniqueConstraint columnNames="token"
                             constraintName="uc_refreshtoken_token"
                             tableName="RefreshToken"/>
    </changeSet>
    <changeSet id="1771841226713-4"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="RefreshToken"
                                 constraintName="FK_REFRESHTOKEN_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>
    <changeSet id="1771841255749-1" author="bethibande">
        <createIndex tableName="RefreshToken" indexName="refreshtoken_token">
            <column name="token"/>
        </createIndex>
        <createIndex tableName="RefreshToken" indexName="refreshtoken_created">
            <column name="created"/>
        </createIndex>
    </changeSet>
    <changeSet id="1771841344186-1" author="bethibande">
        <createIndex tableName="usersession" indexName="usersession_created">
            <column name="created"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
