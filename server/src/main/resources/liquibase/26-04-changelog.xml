<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1775028501244-2"
               author="bethibande">
        <addColumn tableName="OpenIDConnectProvider">
            <column name="authorizationEndpoint"
                    type="varchar(512)"/>
            <column name="tokenEndpoint"
                    type="varchar(512)"/>
            <column name="userInfoEndpoint"
                    type="varchar(512)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775028501244-3"
               author="bethibande">
        <addNotNullConstraint columnName="authorizationEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-5"
               author="bethibande">
        <addNotNullConstraint columnName="tokenEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-7"
               author="bethibande">
        <addNotNullConstraint columnName="userInfoEndpoint"
                              tableName="OpenIDConnectProvider"/>
    </changeSet>
    <changeSet id="1775028501244-1"
               author="bethibande">
        <dropNotNullConstraint columnDataType="varchar(512)"
                               columnName="discoveryUrl"
                               tableName="OpenIDConnectProvider"/>
    </changeSet>

    <changeSet id="1775289642505-1"
               author="bethibande">
        <addColumn tableName="UserSession">
            <column name="address"
                    type="varchar(512)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775290794930-1" author="bethibande">
        <sql>
            UPDATE usersession SET address = ''
        </sql>
    </changeSet>
    <changeSet id="1775289642505-2"
               author="bethibande">
        <addNotNullConstraint columnName="address"
                              tableName="UserSession"/>
    </changeSet>

    <changeSet id="1775291640786-1"
               author="bethibande">
        <addColumn tableName="UserSession">
            <column name="refreshToken_id"
                    type="BIGINT"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775291669515-1" author="bethibande">
        <!-- Invalidate all active sessions due to database validation constraints, the frontend will automatically renew them anyway -->
        <sql>
            DELETE FROM usersession
        </sql>
    </changeSet>
    <changeSet id="1775291640786-2"
               author="bethibande">
        <addNotNullConstraint columnName="refreshToken_id"
                              tableName="UserSession"/>
    </changeSet>
    <changeSet id="1775291640786-3"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="refreshToken_id"
                                 baseTableName="UserSession"
                                 constraintName="FK_USERSESSION_ON_REFRESHTOKEN"
                                 referencedColumnNames="id"
                                 referencedTableName="RefreshToken"/>
    </changeSet>

</databaseChangeLog>
