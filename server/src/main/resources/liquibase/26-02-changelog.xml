<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.33.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1769943556375-1"
               author="bethibande">
        <createSequence incrementBy="50"
                        sequenceName="StoredFile_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1769943556375-2"
               author="bethibande">
        <createTable tableName="ArtifactVersion_files">
            <column name="ArtifactVersion_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="files_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769943556375-3"
               author="bethibande">
        <createTable tableName="StoredFile">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_storedfile"/>
            </column>
            <column name="repository_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="key"
                    type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769943556375-4"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="repository_id"
                                 baseTableName="StoredFile"
                                 constraintName="FK_STOREDFILE_ON_REPOSITORY"
                                 referencedColumnNames="id"
                                 referencedTableName="Repository"/>
    </changeSet>
    <changeSet id="1769943556375-5"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="ArtifactVersion_id"
                                 baseTableName="ArtifactVersion_files"
                                 constraintName="fk_artfil_on_artifact_version"
                                 referencedColumnNames="id"
                                 referencedTableName="ArtifactVersion"/>
    </changeSet>
    <changeSet id="1769943556375-6"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="files_id"
                                 baseTableName="ArtifactVersion_files"
                                 constraintName="fk_artfil_on_stored_file"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>

    <changeSet id="1769950427746-1"
               author="bethibande">
        <createTable tableName="Artifact_files">
            <column name="Artifact_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="files_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1769950427746-2"
               author="bethibande">
        <addColumn tableName="StoredFile">
            <column name="created"
                    type="timestamptz"/>
            <column name="hashes"
                    type="jsonb"/>
            <column name="updated"
                    type="timestamptz"/>
        </addColumn>
    </changeSet>
    <changeSet id="1769950427746-3"
               author="bethibande">
        <addNotNullConstraint columnName="created"
                              tableName="StoredFile"/>
    </changeSet>
    <changeSet id="1769950427746-6"
               author="bethibande">
        <addNotNullConstraint columnName="updated"
                              tableName="StoredFile"/>
    </changeSet>
    <changeSet id="1769950427746-7"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="Artifact_id"
                                 baseTableName="Artifact_files"
                                 constraintName="fk_artfil_on_artifact"
                                 referencedColumnNames="id"
                                 referencedTableName="Artifact"/>
    </changeSet>
    <changeSet id="1769950427746-8"
               author="bethibande">
        <addForeignKeyConstraint baseColumnNames="files_id"
                                 baseTableName="Artifact_files"
                                 constraintName="fk_artfil_on_stored_file"
                                 referencedColumnNames="id"
                                 referencedTableName="StoredFile"/>
    </changeSet>

    <changeSet id="1769969568855-1" author="bethibande">
        <sql>
            UPDATE repository SET packagemanager = 'MAVEN' WHERE packagemanager = 'MAVEN_3';
        </sql>
    </changeSet>

    <changeSet id="1770035947861-1"
               author="bethibande">
        <addColumn tableName="Repository">
            <column name="cleanupPolicies"
                    type="jsonb"/>
        </addColumn>
    </changeSet>

    <changeSet id="1770114595082-1"
               author="behtibande">
        <createSequence incrementBy="50"
                        sequenceName="TaskLock_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1770114595082-2"
               author="behtibande">
        <createTable tableName="TaskLock">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_tasklock"/>
            </column>
            <column name="taskId"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="doNotExecuteBefore"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="lock"
                    type="varchar(255)"/>
            <column name="lockEnd"
                    type="timestamptz"/>
            <column name="lastSuccess"
                    type="timestamptz"/>
        </createTable>
    </changeSet>
    <changeSet id="1770114595082-3"
               author="behtibande">
        <addUniqueConstraint columnNames="taskId"
                             constraintName="uc_tasklock_taskid"
                             tableName="TaskLock"/>
    </changeSet>

    <changeSet id="1770133651187-1"
               author="behtibande">
        <createSequence incrementBy="50"
                        sequenceName="UserSession_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1770133651187-2"
               author="behtibande">
        <createTable tableName="UserSession">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_usersession"/>
            </column>
            <column name="token"
                    type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="device"
                    type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created"
                    type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1770133651187-3"
               author="behtibande">
        <addUniqueConstraint columnNames="token"
                             constraintName="uc_usersession_token"
                             tableName="UserSession"/>
    </changeSet>
    <changeSet id="1770133651187-4"
               author="behtibande">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="UserSession"
                                 constraintName="FK_USERSESSION_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="Users"/>
    </changeSet>
    <changeSet id="1770134319183-1" author="bethibande">
        <createIndex tableName="UserSession" indexName="idx_usersession_token">
            <column name="token"/>
        </createIndex>
    </changeSet>
    <changeSet id="1770136876985-1" author="bethibande">
        <dropColumn tableName="UserSession">
            <column name="device"/>
        </dropColumn>
    </changeSet>
</databaseChangeLog>
